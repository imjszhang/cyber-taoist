{
  "name": "cyber-taoist",
  "private": true,
  "type": "module",
  "bin": {
    "cybertaoist": "./cli/cli.js"
  },
  "scripts": {
    "search": "node scripts/flomo-import/search-flomo.mjs",
    "review": "node scripts/flomo-import/generate-review.mjs",
    "atoms": "node scripts/flomo-import/generate-atoms.mjs",
    "site:dev": "npx serve site/src",
    "site:build": "node build/build.js",
    "site:preview": "npx serve docs -l 3000",
    "cli": "node cli/cli.js",
    "cf:setup": "node scripts/setup-cloudflare.js",
    "gh:pages": "node scripts/setup-github-pages.js",
    "deploy:setup": "npm run cf:setup && npm run gh:pages"
  }
}
