KNOWLEDGE_PRISM_API_BASE_URL=http://localhost:8888/v1
KNOWLEDGE_PRISM_API_MODEL=qwen3.5
KNOWLEDGE_PRISM_API_KEY=your-api-key-here

# ── 站点部署（GitHub Pages + Cloudflare）────────────────
# 自定义域名，默认 cyber-taoist.ai
# DEPLOY_DOMAIN=cyber-taoist.ai
# 若 fork 仓库，可显式指定 owner/repo（否则从 git remote.origin 推断）
# GITHUB_REPO=imjszhang/cyber-taoist
# CNAME 目标，默认 <owner>.github.io
# GITHUB_PAGES_CNAME_TARGET=imjszhang.github.io
# 新建 Pages 时参考分支（脚本会优先沿用仓库已有 Pages 配置）
# PAGES_BRANCH=main

# Cloudflare：https://dash.cloudflare.com/profile/api-tokens
# 需 Zone:Read, Zone:Edit, DNS:Edit（或使用 Global API Key + 邮箱）
# CLOUDFLARE_API_TOKEN=
# CLOUDFLARE_EMAIL=
# CLOUDFARE_API_KEY=

# GitHub：https://github.com/settings/tokens ，需 repo 或 Pages 写权限
# GITHUB_TOKEN=
